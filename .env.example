# ─── Firebase ──────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Sentry (Error Monitoring) ─────────────────────────────────
# Get from: https://sentry.io → Create Project → React → DSN
VITE_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
# Set to "true" to also log in development
VITE_SENTRY_DEV=false

# ─── App ───────────────────────────────────────────────────────
VITE_APP_VERSION=1.0.0

# ─── Testing ───────────────────────────────────────────────────
# Dedicated test account (do NOT use your real account)
TEST_EMAIL=test@karyika.app
TEST_PASSWORD=Test@123456
TEST_URL=http://localhost:5173
